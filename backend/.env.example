# ─── ExpenseIQ Backend Environment Variables ───

# Application
PORT=5000
NODE_ENV=development
# For production, set to your Vercel URL: https://expense-iq.vercel.app
CORS_ORIGIN=http://localhost:3000

# Security
# Run `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` to generate a secure secret
JWT_SECRET=your_super_secret_jwt_key_that_is_at_least_32_chars_long
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Database (Neon / PostgreSQL)
# Example: postgresql://username:password@ep-cool-sun-123456.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://user:password@localhost:5432/expense_iq?schema=public

# Redis (Upstash)
# Example: redis://default:password@us1-cool-sun-12345.upstash.io:32345
REDIS_URL=redis://localhost:6379

# AI Provider (Groq)
# Get a key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
